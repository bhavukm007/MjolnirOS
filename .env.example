MJOLNIROS_ENVIRONMENT=development
MJOLNIROS_HOST=127.0.0.1
MJOLNIROS_PORT=8000
MJOLNIROS_LOG_LEVEL=INFO
MJOLNIROS_FRONTEND_URL=http://localhost:5173
MJOLNIROS_DEFAULT_MODEL=qwen2.5:3b
MJOLNIROS_VISION_UPLOAD_DIRECTORY=database/documents
MJOLNIROS_VISION_MAX_UPLOAD_BYTES=20000000
MJOLNIROS_VISION_MAX_EXTRACT_CHARACTERS=100000
# Optional: full path to tesseract.exe when it is not discoverable automatically.
# MJOLNIROS_TESSERACT_COMMAND=C:\Program Files\Tesseract-OCR\tesseract.exe
MJOLNIROS_OLLAMA_URL=http://127.0.0.1:11434
MJOLNIROS_AUTOMATION_STORAGE_DIRECTORY=database/automation
MJOLNIROS_LEARNING_STORAGE_DIRECTORY=database/learning
MJOLNIROS_LEARNING_SUGGESTION_THRESHOLD=3
# OAuth client credentials are optional until a productivity plugin is connected.
MJOLNIROS_GOOGLE_OAUTH_CLIENT_ID=
MJOLNIROS_GOOGLE_OAUTH_CLIENT_SECRET=
MJOLNIROS_GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/v1/productivity/oauth/google/callback
MJOLNIROS_NOTION_OAUTH_CLIENT_ID=
MJOLNIROS_NOTION_OAUTH_CLIENT_SECRET=
MJOLNIROS_NOTION_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/v1/productivity/oauth/notion/callback
