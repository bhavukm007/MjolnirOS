MJOLNIROS_ENVIRONMENT=development
MJOLNIROS_HOST=127.0.0.1
MJOLNIROS_PORT=8000
MJOLNIROS_LOG_LEVEL=INFO
MJOLNIROS_FRONTEND_URL=http://localhost:5173
MJOLNIROS_DEFAULT_MODEL=qwen2.5:3b
MJOLNIROS_OLLAMA_BASE_URL=http://127.0.0.1:11434/api
MJOLNIROS_OLLAMA_TIMEOUT_SECONDS=120
MJOLNIROS_VOICE_ENABLED=true
MJOLNIROS_VOICE_MODEL_PATH=assets/models/vosk-model-small-en-us-0.15
MJOLNIROS_VOICE_SAMPLE_RATE=16000
MJOLNIROS_VOICE_WAKE_WORD=Mjolnir
MJOLNIROS_VOICE_TTS_RATE=185
MJOLNIROS_VOICE_TTS_VOLUME=1.0
