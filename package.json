{
  "name": "mjolniros",
  "version": "1.1.0",
  "private": true,
  "description": "Local-first Windows desktop operating assistant.",
  "keywords": [
    "ai-assistant",
    "local-first",
    "windows",
    "electron",
    "fastapi",
    "react",
    "ollama",
    "voice-assistant",
    "automation"
  ],
  "homepage": "https://github.com/bhavukm007/MjolnirOS#readme",
  "bugs": {
    "url": "https://github.com/bhavukm007/MjolnirOS/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhavukm007/MjolnirOS.git"
  },
  "author": "Bhavuk Mahajan",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "main": "desktop/main.js",
  "build": {
    "appId": "com.mjolniros.desktop",
    "productName": "MjolnirOS",
    "win": {
      "icon": "assets/branding/mjolnir.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "assets/branding/mjolnir.ico",
      "uninstallerIcon": "assets/branding/mjolnir.ico"
    }
  },
  "scripts": {
    "dev": "node desktop/dev.js",
    "backend:dev": "uvicorn backend.app.main:app --host 127.0.0.1 --port 8000 --reload",
    "backend:test": ".\\.venv\\Scripts\\python.exe -m pytest --basetemp .pytest_tmp",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:test": "npm run test --prefix frontend",
    "desktop:dev": "electron .",
    "desktop:check": "node --check desktop/main.js && node --check desktop/preload.js",
    "launch:smoke": "electron . --smoke",
    "test": "npm run backend:test && npm run frontend:test && npm run desktop:check",
    "build": "npm run frontend:build && npm run desktop:check"
  },
  "devDependencies": {
    "electron": "40.10.2"
  }
}
