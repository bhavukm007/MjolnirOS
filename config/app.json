{
  "app_name": "MjolnirOS",
  "environment": "development",
  "host": "127.0.0.1",
  "port": 8000,
  "api_prefix": "/api/v1",
  "log_level": "INFO",
  "log_file": "logs/mjolniros.log",
  "frontend_url": "http://localhost:5173",
  "default_model": "qwen2.5:3b",
  "ollama_base_url": "http://127.0.0.1:11434/api",
  "ollama_timeout_seconds": 120.0,
  "voice_enabled": true,
  "voice_model_path": "assets/models/vosk-model-small-en-us-0.15",
  "voice_sample_rate": 16000,
  "voice_wake_word": "Mjolnir",
  "voice_tts_rate": 185,
  "voice_tts_volume": 1.0,
  "database_path": "database/mjolniros.db",
  "chroma_path": "database/chroma",
  "windows_search_root": "C:/Users",
  "windows_screenshot_path": "assets/screenshots",
  "browser_session_path": "database/browser_sessions",
  "browser_download_path": "assets/downloads",
  "browser_screenshot_path": "assets/browser_screenshots",
  "browser_headless": false,
  "browser_summary_timeout_seconds": 30,
  "github_api_base_url": "https://api.github.com",
  "github_default_repository": ".",
  "coding_vscode_command": "code",
  "coding_project_roots": ["."],
  "coding_command_timeout_seconds": 120,
  "coding_ai_max_context_chars": 12000,
  "enabled_foundation_modules": [
    "backend",
    "frontend",
    "desktop",
    "ai",
    "voice",
    "memory",
    "windows",
    "browser",
    "configuration",
    "logging"
  ]
}
