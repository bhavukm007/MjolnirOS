{
  "app_name": "MjolnirOS",
  "environment": "development",
  "host": "127.0.0.1",
  "port": 8000,
  "api_prefix": "/api/v1",
  "log_level": "INFO",
  "log_file": "logs/mjolniros.log",
  "frontend_url": "http://localhost:5173",
  "default_model": "qwen2.5:3b",
  "enabled_foundation_modules": [
    "backend",
    "frontend",
    "desktop",
    "configuration",
    "logging",
    "vision",
    "documents",
    "automation",
    "planner",
    "learning",
    "plugins"
  ],
  "vision_upload_directory": "database/documents",
  "vision_max_upload_bytes": 20000000,
  "vision_max_extract_characters": 100000,
  "ollama_url": "http://127.0.0.1:11434",
  "automation_storage_directory": "database/automation",
  "learning_storage_directory": "database/learning",
  "learning_suggestion_threshold": 3,
  "plugin_directory": "plugins",
  "plugin_catalog_file": "plugins/catalog.json",
  "plugin_state_file": "database/plugins/state.json",
  "plugin_load_timeout_seconds": 5
}
